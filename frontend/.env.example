# Frontend build-time variables (public — inlined by Vite into the JS bundle).
# Copy to frontend/.env and fill in real values.
# NEVER put secret keys here — these values are visible in the browser bundle.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ENABLE_GOOGLE_OAUTH=false
