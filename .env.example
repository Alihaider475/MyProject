# SafeSite AI — environment variable template (placeholders only, never real secrets).
# Copy this file to .env and fill in real values.  .env is git-ignored.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=prod
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# Supabase cloud PostgreSQL or any compatible URL.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/safesite

# ── Redis cache (optional — falls back to in-memory if unset) ─────────────────
REDIS_URL=redis://redis:6379/0

# ── Supabase Auth ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── YOLO Model & Detection ─────────────────────────────────────────────────────
# Use ppe.pt (PyTorch, default) or ppe.onnx (ONNX — faster cold start, no JIT delay).
# Export ppe.onnx once with: python scripts/export_onnx.py
MODEL_PATH=data/models/ppe.pt
DETECTION_CONFIDENCE=0.25
VIOLATION_CONFIDENCE=0.25
ENABLE_HARDHAT_COLOR_VETO=false

# ── Streaming ──────────────────────────────────────────────────────────────────
STREAM_WIDTH=640
STREAM_HEIGHT=480
STREAM_TARGET_FPS=15

# ── SMTP Email Alerts ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@yourcompany.com
SMTP_PASSWORD=your-app-password-not-account-password
SENDER_EMAIL=alerts@yourcompany.com
RECEIVER_EMAIL=manager@yourcompany.com

# ── MQTT Alerts (optional) ─────────────────────────────────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=safesite/violations
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Webhook / Slack Alerts (optional) ─────────────────────────────────────────
WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# ── Face Recognition ───────────────────────────────────────────────────────────
FACE_MATCH_THRESHOLD=0.40
FACE_DETECTOR_BACKEND=yunet

# ── Fines ──────────────────────────────────────────────────────────────────────
FINES_ENABLED=true
DEFAULT_HARDHAT_FINE=500.0
DEFAULT_VEST_FINE=300.0
DEFAULT_MASK_FINE=200.0

# ── Person Tracking ────────────────────────────────────────────────────────────
TRACKING_ENABLED=true

# ── n8n Agent Integration ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
N8N_PAYROLL_AGENT_API_KEY=replace-with-a-long-random-string
N8N_SAFETY_ACTION_AGENT_API_KEY=replace-with-a-different-long-random-string
EFFECTIVENESS_REVIEW_WINDOW_DAYS=0
# Webhook URL from the n8n Payroll Risk Analysis workflow Webhook Trigger node.
# n8n must have a "Respond to Webhook" node that returns immediately.
N8N_PAYROLL_WORKFLOW_WEBHOOK_URL=https://coorporate2026.app.n8n.cloud/webhook/payroll-risk-analysis-run
# Webhook URL from the n8n Safety Effectiveness Review workflow Webhook Trigger node.
N8N_SAFETY_EFFECTIVENESS_WEBHOOK_URL=https://coorporate2026.app.n8n.cloud/webhook/safety-effectiveness-run
