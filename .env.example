# Copy this file to .env and fill in the secrets. Do NOT commit your real .env.
#   cp .env.example .env

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# SQLite for local development (default, no external service required)
DATABASE_URL=sqlite+aiosqlite:///./ppe_detection.db
# PostgreSQL / Supabase for production:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:6543/postgres

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=data/models/ppe.pt
DETECTION_CONFIDENCE=0.5

# ── Alert timing ──────────────────────────────────────────────────────────────
ALERT_COOLDOWN_SECONDS=30
VIOLATION_PERSIST_SECONDS=30

# ── Live stream ───────────────────────────────────────────────────────────────
STREAM_WIDTH=640            # 0 = keep original resolution
STREAM_HEIGHT=480
STREAM_JPEG_QUALITY=75      # 1-100
STREAM_TARGET_FPS=30        # stream fps (detection runs async)

# ── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
# HS256 JWT secret for fast local token verification (Dashboard -> Project Settings -> API -> JWT Secret).
# Leave empty to verify tokens via the Supabase API instead (slower, but works without the secret).
SUPABASE_JWT_SECRET=

# ── Email alerts ──────────────────────────────────────────────────────────────
SENDER_EMAIL=
RECEIVER_EMAIL=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_RETRY_COUNT=3
EMAIL_RETRY_DELAY=5

# ── Webhook alerts ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
WEBHOOK_URL=

# ── MQTT alerts - leave MQTT_BROKER empty to disable ─────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=ppe/alerts
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_KEEPALIVE=60
MQTT_RETRY_COUNT=3
MQTT_RETRY_DELAY=5
MQTT_CLIENT_ID=ppe-detection-server

# ── PLC siren (Modbus TCP) - leave PLC_HOST empty to disable ─────────────────
PLC_HOST=
PLC_PORT=502
PLC_UNIT_ID=1
PLC_COIL_ADDRESS=0
PLC_COIL_DURATION=5
PLC_TIMEOUT=3
PLC_RETRY_COUNT=3
PLC_RETRY_DELAY=5

# ── Fines / salary deduction ─────────────────────────────────────────────────
FINES_ENABLED=true
FINES_CURRENCY=PKR
