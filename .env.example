# Application
APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./ppe_detection.db
# DATABASE_URL=postgresql+asyncpg://ppe:ppe@db:5432/ppe_detection

# Model
MODEL_PATH=models/ppe.pt
DETECTION_CONFIDENCE=0.5

# Alert timing (seconds)
ALERT_COOLDOWN_SECONDS=10
VIOLATION_PERSIST_SECONDS=10

# Live stream tuning
STREAM_WIDTH=960            # 0 = keep original resolution
STREAM_HEIGHT=540
STREAM_JPEG_QUALITY=80      # 1–100 (lower = smaller bandwidth, blurrier)
STREAM_TARGET_FPS=15        # 0 = unbounded (will pin 100% CPU)

# Email alerts (Gmail — requires App Password)
SENDER_EMAIL=your_email@gmail.com
RECEIVER_EMAIL=receiver_email@example.com
EMAIL_PASSWORD=your_app_password
EMAIL_RETRY_COUNT=3       # max send attempts before giving up
EMAIL_RETRY_DELAY=5       # seconds between retry attempts

# Optional: Slack webhook
SLACK_WEBHOOK_URL=

# Optional: Generic webhook
WEBHOOK_URL=

# MQTT alerts — leave MQTT_BROKER empty to disable
MQTT_BROKER=
MQTT_PORT=1883
MQTT_TOPIC=ppe/violations/camera_{camera_id}
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1              # 0=fire-and-forget, 1=at-least-once (recommended), 2=exactly-once
MQTT_KEEPALIVE=60       # seconds between broker keepalive pings
MQTT_RETRY_COUNT=3      # max publish attempts before giving up
MQTT_RETRY_DELAY=5      # seconds between retry attempts
MQTT_CLIENT_ID=ppe-detection-server   # unique broker session ID

# PLC siren (Modbus TCP) — leave PLC_HOST empty to disable
PLC_HOST=
PLC_PORT=502
PLC_UNIT_ID=1               # Modbus slave/unit ID
PLC_COIL_ADDRESS=0          # coil register that activates the siren relay
PLC_COIL_DURATION=5         # seconds coil stays HIGH before auto-reset to LOW
PLC_TIMEOUT=3               # TCP connection timeout in seconds
PLC_RETRY_COUNT=3           # max connection attempts before giving up
PLC_RETRY_DELAY=5           # seconds between retry attempts
