# syntax=docker/dockerfile:1
#
# SafeSite AI — frontend production image.
# Stage 1: Vite builds the React SPA (requires frontend/.env for VITE_* public vars).
# Stage 2: nginx serves the compiled SPA on :80 and proxies /api/* to the backend.

# ---------------------------------------------------------------------------
# Stage 1 — Vite build
# ---------------------------------------------------------------------------
FROM node:20-alpine AS build

WORKDIR /frontend

# Install dependencies first for layer caching.
COPY frontend/package*.json ./
RUN npm ci

# vite.config.js sets outDir: '../dist', so the compiled SPA lands at /dist
# (one level above WORKDIR /frontend).
COPY frontend/ ./
RUN npm run build

# ---------------------------------------------------------------------------
# Stage 2 — nginx runtime
# ---------------------------------------------------------------------------
FROM nginx:stable-alpine AS frontend

# Copy compiled SPA from build stage.
COPY --from=build /dist /usr/share/nginx/html

# nginx site config: SPA routing + API proxy + WebSocket + MJPEG passthrough.
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
