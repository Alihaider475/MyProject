# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for dev; swap to PostgreSQL for prod
DATABASE_URL=sqlite+aiosqlite:///./ppe_detection.db
# DATABASE_URL=postgresql+asyncpg://ppe:ppe@db:5432/ppe_detection

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=models/ppe.pt
DETECTION_CONFIDENCE=0.5

# ── Alert timing ──────────────────────────────────────────────────────────────
ALERT_COOLDOWN_SECONDS=10
VIOLATION_PERSIST_SECONDS=10

# ── Live stream ───────────────────────────────────────────────────────────────
STREAM_WIDTH=960            # 0 = keep original resolution
STREAM_HEIGHT=540
STREAM_JPEG_QUALITY=80      # 1–100
STREAM_TARGET_FPS=15        # 0 = unbounded

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Email alerts (Gmail — requires App Password) ──────────────────────────────
SENDER_EMAIL=ha70131295@gmail.com
RECEIVER_EMAIL=receiver_email@example.com
EMAIL_PASSWORD=your_app_password
EMAIL_RETRY_COUNT=3
EMAIL_RETRY_DELAY=5

# ── Webhook alerts ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
WEBHOOK_URL=

# ── MQTT alerts — leave MQTT_BROKER empty to disable ─────────────────────────
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=ppe/alerts
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_KEEPALIVE=60
MQTT_RETRY_COUNT=3
MQTT_RETRY_DELAY=5
MQTT_CLIENT_ID=ppe-detection-server

# ── PLC siren (Modbus TCP) — leave PLC_HOST empty to disable ─────────────────
PLC_HOST=
PLC_PORT=502
PLC_UNIT_ID=1
PLC_COIL_ADDRESS=0
PLC_COIL_DURATION=5
PLC_TIMEOUT=3
PLC_RETRY_COUNT=3
PLC_RETRY_DELAY=5
