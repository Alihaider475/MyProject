# Keep the build context small and secrets out of the image.
.git/
.venv/
**/__pycache__/
node_modules/
frontend/node_modules/
dist/                        # rebuilt inside Dockerfile.frontend
.pytest_cache/
.ruff_cache/
tests/
data/violation_frames/
*.db
*.db-journal
*.log
.DS_Store
docs/
scripts/
requirements/legacy-frozen.txt
requirements/yolo_env.yml

# Secrets: ignore ONLY the root .env (anchored with leading /) so it is never
# baked into either image.  It is supplied at runtime via env_file in compose.
/.env
!frontend/.env               # public VITE_* vars needed by the Vite build stage

# NOTE: do NOT ignore data/models/ — ppe.pt must be copied into the backend image.
